@page "/app/materials"
@model Mathly.Pages.Student.MaterialsModel
@{
    Layout = "_LayoutStudent";
    ViewData["Title"] = "Materials";
    ViewData["ActivePage"] = "Materials";
}

@section Styles {
    <link rel="stylesheet" href="~/css/student/StudentMaterials.css" asp-append-version="true" />
}

<div class="page-header">
    <h1 class="page-title">📂 Materials</h1>
    <p class="page-subtitle">Study materials from the topics you've joined</p>
</div>

<div class="content-card">
    @if (Model.Materials.Any())
    {
        @foreach (var group in Model.Materials.GroupBy(m => m.TopicName))
        {
            <div class="quiz-topic-group">
                <div class="quiz-topic-group-name">@group.Key</div>
                @foreach (var m in group)
                {
                    <div class="material-row">
                        <span class="material-icon">📄</span>
                        <span class="material-name">@m.FileName</span>
                    </div>
                }
            </div>
        }
    }
    else
    {
        <div class="empty-state">No materials yet — join a topic to see its materials here.</div>
    }
</div>
