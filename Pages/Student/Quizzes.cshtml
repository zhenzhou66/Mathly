@page "/app/quizzes"
@model Mathly.Pages.Student.QuizzesModel
@{
    Layout = "_LayoutStudent";
    ViewData["Title"] = "Quizzes";
    ViewData["ActivePage"] = "Quizzes";
}

@section Styles {
    <link rel="stylesheet" href="~/css/student/StudentQuizzes.css" asp-append-version="true" />
}

<div class="page-header">
    <h1 class="page-title">📝 Quizzes</h1>
    <p class="page-subtitle">Quizzes from the topics you've joined</p>
</div>

<div class="content-card">
    @if (Model.Quizzes.Any())
    {
        @foreach (var group in Model.Quizzes.GroupBy(q => q.TopicName))
        {
            <div class="quiz-topic-group">
                <div class="quiz-topic-group-name">@group.Key</div>
                @foreach (var q in group)
                {
                    <div class="quiz-row">
                        <div class="quiz-row-title">@q.QuizTitle</div>
                        <div class="quiz-row-actions">
                            @if (q.BestScore.HasValue)
                            {
                                <span class="quiz-status-pill quiz-status-done">Best score: @q.BestScore.Value.ToString("0")%</span>
                            }
                            else
                            {
                                <span class="quiz-status-pill quiz-status-pending">Not attempted</span>
                            }
                            <a asp-page="/Student/AttemptQuiz" asp-route-quizId="@q.QuizID" class="btn-add-topic">Attempt Quiz</a>
                        </div>
                    </div>
                }
            </div>
        }
    }
    else
    {
        <div class="empty-state">No quizzes yet — join a topic to see its quizzes here.</div>
    }
</div>
