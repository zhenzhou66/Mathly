@page "/app/daily"
@model Mathly.Pages.Student.DailyModel
@{
    Layout = "_LayoutStudent";
    ViewData["Title"] = "Daily Quiz Arena";
    ViewData["ActivePage"] = "Daily";
}

@section Styles {
    <link rel="stylesheet" href="~/css/student/StudentDaily.css" asp-append-version="true" />
}

<!-- Daily Hero Banner -->
<div class="daily-hero mb-4">
    <div class="daily-title-badge">⚡ DAILY MATH ARENA</div>
    <h1 class="daily-hero-heading">Today's Daily Challenge 🚀</h1>
    <p class="daily-hero-sub">
        Test your skills in today's rapid-fire math quiz! Complete the daily challenge to earn extra XP, maintain your streak, and climb the podium leaderboard.
    </p>

    <!-- Timer Countdown -->
    <div class="timer-container">
        <span class="timer-label">Resets In</span>
        <span class="timer-clock" id="dailyCountdown">10 : 45 : 22</span>
    </div>
</div>

<!-- Lobby Main Grid -->
<div class="row g-4">
    <!-- Main Quiz Details Card -->
    <div class="col-lg-7">
        <div class="daily-card">
            <div class="daily-card-header">
                <div class="daily-card-title">📌 Quiz Overview</div>
                <span class="meta-pill">Topic: @Model.TopicName</span>
            </div>

            <h3 class="fw-bold mb-3 text-dark">@Model.DailyQuizTitle</h3>

            <div class="detail-grid">
                <div class="detail-item">
                    <div class="detail-icon">❓</div>
                    <div class="detail-label">Questions</div>
                    <div class="detail-val">@Model.TotalQuestions Questions</div>
                </div>
                <div class="detail-item">
                    <div class="detail-icon">⏱️</div>
                    <div class="detail-label">Time Limit</div>
                    <div class="detail-val">@Model.EstimatedMinutes Mins</div>
                </div>
                <div class="detail-item">
                    <div class="detail-icon">⭐</div>
                    <div class="detail-label">XP Reward</div>
                    <div class="detail-val">+@Model.ExpPointsReward XP</div>
                </div>
                <div class="detail-item">
                    <div class="detail-icon">👥</div>
                    <div class="detail-label">Completed Today</div>
                    <div class="detail-val">@Model.ParticipantsTodayCount Students</div>
                </div>
            </div>

            @if (Model.HasCompletedToday)
            {
                <div class="completed-banner mb-3">
                    <div class="completed-icon">🎉</div>
                    <div class="completed-title">You Completed Today's Quiz!</div>
                    <div class="completed-desc">
                        Score: <strong>@Model.UserTodayScore.ToString("0")%</strong> (@Model.UserTodayCorrect/@Model.TotalQuestions correct). Check your position on the leaderboard!
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <button type="button" class="btn-start-daily flex-fill" data-bs-toggle="modal" data-bs-target="#quizArenaModal">
                        🎮 Play Again
                    </button>
                    <a href="/daily/leaderboard" class="btn-start-daily flex-fill text-center" style="background: linear-gradient(135deg, #1E293B 0%, #0F172A 100%);">
                        🏆 Podium →
                    </a>
                </div>
            }
            else
            {
                <button type="button" class="btn-start-daily" data-bs-toggle="modal" data-bs-target="#quizArenaModal">
                    🚀 Start Daily Quiz Now
                </button>
            }
        </div>
    </div>

    <!-- Live Takers & Rules Side Panel -->
    <div class="col-lg-5">
        <!-- Rules Card -->
        <div class="daily-card mb-4" style="background: #F8FAFC;">
            <div class="daily-card-title mb-3">📜 Arena Rules</div>
            <ul class="list-unstyled text-secondary small mb-0" style="line-height: 1.8;">
                <li>• <strong>One Attempt:</strong> Today's challenge score counts towards daily XP.</li>
                <li>• <strong>Instant Feedback:</strong> See your score and XP breakdown immediately upon submit.</li>
                <li>• <strong>Leaderboard Boost:</strong> Higher scores boost your position on the Hall of Fame!</li>
            </ul>
        </div>

        <!-- Recent Takers Card -->
        <div class="daily-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="daily-card-title">🔥 Today's Finishers</div>
                <span class="badge bg-success bg-opacity-10 text-success fw-bold px-2 py-1">LIVE</span>
            </div>

            @if (Model.TodayParticipants.Any())
            {
                foreach (var taker in Model.TodayParticipants)
                {
                    <div class="taker-item">
                        <div class="taker-avatar">@taker.AvatarChar</div>
                        <div class="taker-info">
                            <div class="taker-name">@taker.StudentName</div>
                        </div>
                        <div class="taker-score">@taker.Score.ToString("0")%</div>
                    </div>
                }
            }
            else
            {
                <p class="text-muted small mb-0">No takers yet today. Be the first!</p>
            }
        </div>
    </div>
</div>

<!-- Interactive Quiz Arena Modal -->
<div class="modal fade" id="quizArenaModal" tabindex="-1" aria-labelledby="quizArenaModalLabel" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px; overflow: hidden;">
            <form method="post" asp-page-handler="SubmitQuiz">
                <input type="hidden" asp-for="ActiveQuizID" />

                <div class="modal-header bg-dark text-white p-4">
                    <div>
                        <span class="badge bg-warning text-dark fw-bold mb-1">LIVE ARENA</span>
                        <h4 class="modal-title fw-bold" id="quizArenaModalLabel">@Model.DailyQuizTitle</h4>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body p-4" style="max-height: 70vh; overflow-y: auto;">
                    @if (Model.QuizQuestions.Any())
                    {
                        int qNum = 1;
                        foreach (var q in Model.QuizQuestions)
                        {
                            <div class="mb-4 p-3 border rounded-3 bg-light">
                                <div class="fw-bold text-dark mb-3">
                                    <span class="badge bg-primary me-2">Q@qNum</span> @q.QuestionText
                                </div>
                                <div class="row g-2">
                                    <div class="col-6">
                                        <div class="form-check p-3 border rounded bg-white">
                                            <input class="form-check-input" type="radio" name="SubmittedAnswers[@q.QuestionID]" id="q_@(q.QuestionID)_A" value="A" required>
                                            <label class="form-check-label w-100 fw-semibold text-secondary" for="q_@(q.QuestionID)_A">
                                                A) @q.ChoiceA
                                            </label>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="form-check p-3 border rounded bg-white">
                                            <input class="form-check-input" type="radio" name="SubmittedAnswers[@q.QuestionID]" id="q_@(q.QuestionID)_B" value="B" required>
                                            <label class="form-check-label w-100 fw-semibold text-secondary" for="q_@(q.QuestionID)_B">
                                                B) @q.ChoiceB
                                            </label>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="form-check p-3 border rounded bg-white">
                                            <input class="form-check-input" type="radio" name="SubmittedAnswers[@q.QuestionID]" id="q_@(q.QuestionID)_C" value="C" required>
                                            <label class="form-check-label w-100 fw-semibold text-secondary" for="q_@(q.QuestionID)_C">
                                                C) @q.ChoiceC
                                            </label>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="form-check p-3 border rounded bg-white">
                                            <input class="form-check-input" type="radio" name="SubmittedAnswers[@q.QuestionID]" id="q_@(q.QuestionID)_D" value="D" required>
                                            <label class="form-check-label w-100 fw-semibold text-secondary" for="q_@(q.QuestionID)_D">
                                                D) @q.ChoiceD
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            qNum++;
                        }
                    }
                    else
                    {
                        <div class="text-center py-4 text-muted">No questions available for this daily quiz.</div>
                    }
                </div>

                <div class="modal-footer bg-light p-3">
                    <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success fw-bold rounded-pill px-5">Submit Quiz Answers 🚀</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function updateTimer() {
            const now = new Date();
            const midnight = new Date();
            midnight.setHours(24, 0, 0, 0);
            
            const diff = midnight - now;
            const hours = Math.floor(diff / (1000 * 60 * 60));
            const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
            const seconds = Math.floor((diff % (1000 * 60)) / 1000);
            
            const pad = (n) => n.toString().padStart(2, '0');
            const timerEl = document.getElementById('dailyCountdown');
            if (timerEl) {
                timerEl.textContent = `${pad(hours)} : ${pad(minutes)} : ${pad(seconds)}`;
            }
        }
        setInterval(updateTimer, 1000);
        updateTimer();
    </script>
}
