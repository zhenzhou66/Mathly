@page
@model Mathly.Pages.Teacher.ProfileModel
@{
    Layout = "_LayoutTeacher";
    ViewData["Title"] = "Profile";
    ViewData["ActivePage"] = "Profile";
    ViewData["TeacherName"] = Model.TeacherName;
}

<div class="page-header">
    <h1 class="page-title">My Profile</h1>
    <p class="page-subtitle">Manage your personal information</p>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success mb-4">@Model.SuccessMessage</div>
}

<div class="row g-4">

    <!-- Hero Card -->
    <div class="col-12">
        <div class="content-card" style="background:#1a1a1a; color:#fff;">
            <div class="d-flex align-items-center gap-4">
                <div style="width:72px;height:72px;border-radius:50%;background:#4CBFBF;display:flex;align-items:center;justify-content:center;font-size:1.6rem;font-weight:700;color:#fff;flex-shrink:0;">
                    @(Model.TeacherName.Substring(0, 1).ToUpper())
                </div>
                <div>
                    <h2 style="font-size:1.4rem;font-weight:700;margin:0 0 0.25rem;">@Model.TeacherName</h2>
                    <p style="color:rgba(255,255,255,0.5);font-size:0.88rem;margin:0;">
                        Mathematics Teacher &middot; Joined @Model.DateJoined
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Edit Form -->
    <div class="col-lg-8">
        <div class="content-card">
            <div class="content-card-title mb-4">Personal Information</div>
            <form method="post">
                <div class="mb-3">
                    <label class="form-label fw-semibold" style="font-size:0.82rem;text-transform:uppercase;letter-spacing:0.04em;color:#888;">
                        Full Name
                    </label>
                    <input asp-for="TeacherNameInput" class="form-control" placeholder="Your full name" />
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold" style="font-size:0.82rem;text-transform:uppercase;letter-spacing:0.04em;color:#888;">
                            Email
                        </label>
                        <input asp-for="Email" class="form-control" type="email" placeholder="your@email.com" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold" style="font-size:0.82rem;text-transform:uppercase;letter-spacing:0.04em;color:#888;">
                            Phone
                        </label>
                        <input asp-for="PhoneNumber" class="form-control" placeholder="+60 1X-XXX XXXX" />
                    </div>
                </div>
                <div class="mb-4">
                    <label class="form-label fw-semibold" style="font-size:0.82rem;text-transform:uppercase;letter-spacing:0.04em;color:#888;">
                        Highest Qualification
                    </label>
                    <input asp-for="HighestQualification" class="form-control" placeholder="e.g. B.Sc. Mathematics" />
                </div>
                <button type="submit" class="btn-new-quiz">Save Changes</button>
            </form>
        </div>
    </div>

    <!-- Account Info -->
    <div class="col-lg-4">
        <div class="content-card">
            <div class="content-card-title mb-3">Account Details</div>
            <div style="display:flex;flex-direction:column;gap:1rem;">
                <div>
                    <div style="font-size:0.78rem;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:#aaa;">User ID</div>
                    <div style="font-size:0.95rem;font-weight:600;color:#1a1a1a;margin-top:0.2rem;">teacher001</div>
                </div>
                <div>
                    <div style="font-size:0.78rem;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:#aaa;">Role</div>
                    <div style="font-size:0.95rem;font-weight:600;color:#1a1a1a;margin-top:0.2rem;">Teacher</div>
                </div>
                <div>
                    <div style="font-size:0.78rem;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:#aaa;">Joined</div>
                    <div style="font-size:0.95rem;font-weight:600;color:#1a1a1a;margin-top:0.2rem;">@Model.DateJoined</div>
                </div>
            </div>
        </div>
    </div>

</div>
