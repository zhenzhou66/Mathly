@page
@model Mathly.Pages.Teacher.QuizBuilderModel
@{
    Layout = "_LayoutTeacher";
    ViewData["Title"] = "Quiz Builder";
    ViewData["ActivePage"] = "QuizBuilder";
    ViewData["TeacherName"] = Model.TeacherName;
}

<div class="page-header">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
        <div>
            <h1 class="page-title">Quiz Builder</h1>
            <p class="page-subtitle">Design polished quizzes with clear questions, strong distractors, and instant publishing flow.</p>
        </div>
        <a asp-page="/Teacher/MyTopics" class="btn-add-topic">Back to topics</a>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-success mb-4">@Model.Message</div>
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="content-card">
            <div class="content-card-title mb-3">Create a new quiz</div>
            <form method="post" asp-page-handler="SaveQuiz">
                <div class="row g-3 mb-3">
                    <div class="col-md-8">
                        <label class="form-label fw-semibold text-uppercase small text-muted">Quiz title</label>
                        <input asp-for="Quiz.Title" class="form-control" placeholder="e.g. Integration Challenge" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold text-uppercase small text-muted">Topic</label>
                        <select asp-for="Quiz.TopicId" class="form-select">
                            <option value="">Select a topic</option>
                            @foreach (var topic in Model.TeacherTopics)
                            {
                                <option value="@topic.TopicID">@topic.TopicName</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <label class="form-label fw-semibold text-uppercase small text-muted">Difficulty</label>
                        <select asp-for="Quiz.Difficulty" class="form-select">
                            <option value="Easy">Easy</option>
                            <option value="Medium">Medium</option>
                            <option value="Hard">Hard</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold text-uppercase small text-muted">Time limit</label>
                        <input asp-for="Quiz.TimeLimit" class="form-control" type="number" min="10" placeholder="20" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold text-uppercase small text-muted">Question count</label>
                        <input asp-for="Quiz.QuestionCount" class="form-control" type="number" min="1" max="12" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold text-uppercase small text-muted">Instructions for students</label>
                    <textarea asp-for="Quiz.Instructions" class="form-control" rows="3" placeholder="Include exam guidance, reminders, and expectations"></textarea>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="content-card-title">Questions</div>
                    <button type="submit" asp-page-handler="AddQuestion" class="btn-edit">+ Add question</button>
                </div>

                @for (var i = 0; i < Model.Questions.Count; i++)
                {
                    <div class="quiz-question-card mb-3">
                        <div class="quiz-question-header">Question @(i + 1)</div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold text-uppercase small text-muted">Question stem</label>
                            <textarea asp-for="Questions[i].QuestionText" class="form-control" rows="3" placeholder="Write the question here"></textarea>
                        </div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Option A</label>
                                <input asp-for="Questions[i].ChoiceA" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Option B</label>
                                <input asp-for="Questions[i].ChoiceB" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Option C</label>
                                <input asp-for="Questions[i].ChoiceC" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Option D</label>
                                <input asp-for="Questions[i].ChoiceD" class="form-control" />
                            </div>
                        </div>
                        <div class="mt-3">
                            <label class="form-label fw-semibold text-uppercase small text-muted">Correct answer</label>
                            <select asp-for="Questions[i].CorrectAnswer" class="form-select">
                                <option value="A">A</option>
                                <option value="B">B</option>
                                <option value="C">C</option>
                                <option value="D">D</option>
                            </select>
                        </div>
                    </div>
                }

                <button type="submit" class="btn-new-quiz">Publish quiz</button>
            </form>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="content-card mb-4">
            <div class="content-card-title mb-3">Quiz workflow</div>
            <div class="quiz-workflow-item">
                <div class="quiz-workflow-number">1</div>
                <div>
                    <div class="fw-semibold">Choose a topic</div>
                    <div class="text-muted small">Keep the quiz closely aligned to the lesson story.</div>
                </div>
            </div>
            <div class="quiz-workflow-item">
                <div class="quiz-workflow-number">2</div>
                <div>
                    <div class="fw-semibold">Write strong distractors</div>
                    <div class="text-muted small">False options should feel believable and useful.</div>
                </div>
            </div>
            <div class="quiz-workflow-item">
                <div class="quiz-workflow-number">3</div>
                <div>
                    <div class="fw-semibold">Publish and review</div>
                    <div class="text-muted small">Students will see the quiz in their learning journey.</div>
                </div>
            </div>
        </div>

        <div class="content-card">
            <div class="content-card-title mb-3">Recent quizzes</div>
            @if (Model.RecentQuizzes.Any())
            {
                @foreach (var quiz in Model.RecentQuizzes)
                {
                    <div class="recent-quiz-item">
                        <div class="fw-semibold">@quiz.Title</div>
                        <div class="small text-muted">@quiz.TopicName · @quiz.QuestionCount questions</div>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">No quizzes yet. Your latest published quizzes will appear here.</div>
            }
        </div>
    </div>
</div>
