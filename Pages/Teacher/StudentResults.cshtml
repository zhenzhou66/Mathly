@page
@model Mathly.Pages.Teacher.StudentResultsModel
@{
    Layout = "_LayoutTeacher";
    ViewData["Title"] = "Student Results";
    ViewData["ActivePage"] = "StudentResults";
    ViewData["TeacherName"] = Model.TeacherName;
}

<div class="page-header">
    <h1 class="page-title">Student Results</h1>
    <p class="page-subtitle">Track how your students are performing across all quizzes</p>
</div>

<!-- Stats Row -->
<div class="row g-3 mb-4">
    <div class="col-sm-4">
        <div class="stat-card stat-card-teal">
            <div class="stat-label">Total Attempts</div>
            <div class="stat-value">@Model.TotalAttempts</div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="stat-card stat-card-green">
            <div class="stat-label">Unique Students</div>
            <div class="stat-value">@Model.UniqueStudents</div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="stat-card stat-card-yellow">
            <div class="stat-label">Class Average</div>
            <div class="stat-value" style="font-size:1.8rem;">@Model.AvgScore</div>
        </div>
    </div>
</div>

<!-- Topic Filter -->
@if (Model.Topics.Any())
{
    <div class="content-card mb-4">
        <div class="d-flex flex-wrap gap-2 align-items-center">
            <span style="font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:#888;">Filter by topic:</span>
            <a asp-page="/Teacher/StudentResults"
               class="results-filter-btn @(string.IsNullOrEmpty(Model.ActiveTopicId) ? "active" : "")">
                All Topics
            </a>
            @foreach (var topic in Model.Topics)
            {
                <a asp-page="/Teacher/StudentResults" asp-route-topicId="@topic.TopicId"
                   class="results-filter-btn @(Model.ActiveTopicId == topic.TopicId ? "active" : "")">
                    @topic.TopicName
                </a>
            }
        </div>
    </div>
}

<!-- Results Table -->
<div class="content-card">
    <div class="content-card-title mb-3">
        @if (string.IsNullOrEmpty(Model.ActiveTopicId))
        {
            <span>All Quiz Results</span>
        }
        else
        {
            <span>@(Model.Topics.FirstOrDefault(t => t.TopicId == Model.ActiveTopicId)?.TopicName) Results</span>
        }
        <span style="font-size:0.8rem;font-weight:400;color:#888;margin-left:0.5rem;">@Model.TotalAttempts attempt@(Model.TotalAttempts == 1 ? "" : "s")</span>
    </div>

    @if (Model.Results.Any())
    {
        <div style="overflow-x:auto;">
            <table class="table topics-table mb-0">
                <thead>
                    <tr>
                        <th>Student</th>
                        <th>Quiz</th>
                        <th>Topic</th>
                        <th>Score</th>
                        <th>Correct</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.Results)
                    {
                        var badgeClass = row.Score >= 80 ? "score-high" : row.Score >= 50 ? "score-mid" : "score-low";
                        <tr>
                            <td style="font-weight:600;">@row.StudentName</td>
                            <td>@row.QuizTitle</td>
                            <td style="color:#888;">@row.TopicName</td>
                            <td>
                                <span class="score-badge @badgeClass">@row.Score.ToString("F0")%</span>
                            </td>
                            <td style="color:#888;">@row.Correct / @row.Total</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">
            No results yet. Results will appear here once students complete quizzes.
        </div>
    }
</div>
