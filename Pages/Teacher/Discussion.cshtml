@page "/teacher/discussion"
@model Mathly.Pages.Teacher.DiscussionModel
@{
    Layout = "_LayoutTeacher";
    ViewData["Title"] = "Discussion";
    ViewData["ActivePage"] = "Discussion";
    ViewData["TeacherName"] = Model.TeacherName;
}

@section Styles {
    <link rel="stylesheet" href="~/css/TeacherDiscussion.css" asp-append-version="true" />
}

<div class="page-header">
    <span class="teacher-view-badge">TEACHER PORTAL</span>
    <h1 class="page-title">💬 Discussion</h1>
    <p class="page-subtitle">Answer student questions and join the conversation</p>
</div>

<div class="content-card mb-3">
    <div class="content-card-title mb-3">Start a new discussion</div>
    <form method="post" class="discussion-form">
        <div class="mb-2">
            <label class="form-label fw-bold text-secondary">Title</label>
            <input asp-for="NewTitle" class="form-control" placeholder="Title" />
        </div>
        <div class="mb-2">
            <label class="form-label fw-bold text-secondary">Question</label>
            <textarea asp-for="NewQuestion" class="form-control" rows="3" placeholder="What's your question?"></textarea>
        </div>
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
                ⚠️ @Model.ErrorMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <button type="submit" class="btn-add-topic">Post question</button>
    </form>
</div>

<div class="content-card">
    <div class="content-card-title mb-3">All discussions</div>
    @if (Model.Threads.Any())
    {
        @foreach (var t in Model.Threads)
        {
            <a asp-page="/Teacher/DiscussionDetail" asp-route-discussionId="@t.DiscussionID" class="discussion-thread-row">
                <div class="discussion-thread-title">@t.QuestionTitle</div>
                <div class="discussion-thread-text">@t.QuestionText</div>
                <div class="discussion-thread-meta">
                    by @t.AuthorName &middot; @t.CommentCount comment@(t.CommentCount == 1 ? "" : "s") &middot; @t.PostedAgo
                </div>
            </a>
        }
    }
    else
    {
        <div class="empty-state">No discussions yet — be the first to ask a question!</div>
    }
</div>
