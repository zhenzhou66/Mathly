@page
@model Mathly.Pages.Teacher.MyTopicsModel
@{
    Layout = "_LayoutTeacher";
    ViewData["Title"] = "My Topics";
    ViewData["ActivePage"] = "MyTopics";
    ViewData["TeacherName"] = Model.TeacherName;
    bool isEditingTopic = !string.IsNullOrEmpty(Model.TopicForm.TopicId);
    bool isEditingChapter = !string.IsNullOrEmpty(Model.ChapterForm.ChapterId);
}

<div class="page-header">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
        <div>
            <h1 class="page-title">My Topics</h1>
            <p class="page-subtitle">Manage your topics and write lesson chapters for students.</p>
        </div>
        <button class="btn-add-topic" type="button" data-bs-toggle="collapse" data-bs-target="#topicFormCard">
            + New Topic
        </button>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-success mb-4">@Model.Message</div>
}

<div class="row g-4">

    <!-- Sidebar: Topic List -->
    <div class="col-xl-4">
        <div class="content-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="content-card-title">Your Topics</div>
                <span class="badge rounded-pill bg-light text-dark" style="font-size:0.78rem;">@Model.Topics.Count</span>
            </div>

            @if (Model.Topics.Any())
            {
                <div class="d-flex flex-column gap-2">
                    @foreach (var topic in Model.Topics)
                    {
                        <a asp-page="/Teacher/MyTopics" asp-route-topicId="@topic.TopicId"
                           class="topic-card @(Model.ActiveTopicId == topic.TopicId ? "active" : "")">
                            <div class="topic-card-title">@topic.Title</div>
                            <div class="topic-card-meta">
                                <span>@topic.ChapterCount chapter@(topic.ChapterCount == 1 ? "" : "s")</span>
                                <span>@topic.QuizCount quiz@(topic.QuizCount == 1 ? "" : "zes")</span>
                                <span>@topic.StudentCount student@(topic.StudentCount == 1 ? "" : "s")</span>
                            </div>
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">No topics yet. Click <strong>+ New Topic</strong> to get started.</div>
            }
        </div>
    </div>

    <!-- Right Panel -->
    <div class="col-xl-8">

        <!-- Topic Form (collapsible) -->
        <div class="content-card mb-4 collapse @(string.IsNullOrEmpty(Model.ActiveTopicId) ? "show" : "")" id="topicFormCard">
            <div class="content-card-title mb-3">
                @(isEditingTopic ? "Edit Topic" : "New Topic")
            </div>
            <form method="post" asp-page-handler="SaveTopic">
                <input asp-for="TopicForm.TopicId" type="hidden" />
                <div class="mb-3">
                    <label class="form-label fw-semibold text-uppercase small text-muted">Topic Title</label>
                    <input asp-for="TopicForm.TopicName" class="form-control" placeholder="e.g. Quadratic Equations" />
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn-new-quiz">
                        @(isEditingTopic ? "Update Topic" : "Create Topic")
                    </button>
                    @if (!string.IsNullOrEmpty(Model.ActiveTopicId))
                    {
                        <a asp-page="/Teacher/MyTopics" asp-route-topicId="@Model.ActiveTopicId" class="btn-edit">Cancel</a>
                    }
                </div>
            </form>
        </div>

        <!-- Chapter Editor (only when a topic is selected) -->
        @if (!string.IsNullOrEmpty(Model.ActiveTopicId))
        {
            <div class="content-card">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <div class="content-card-title">
                            @(isEditingChapter ? "Edit Chapter" : "Add Chapter")
                        </div>
                        <div class="page-subtitle">@Model.ActiveTopicTitle</div>
                    </div>
                    <a asp-page="/Teacher/QuizBuilder" asp-route-topicId="@Model.ActiveTopicId" class="btn-add-topic">
                        + Create Quiz
                    </a>
                </div>

                <!-- Chapter Form -->
                <form method="post" asp-page-handler="SaveChapter" class="mb-4">
                    <input asp-for="ChapterForm.TopicId" type="hidden" value="@Model.ActiveTopicId" />
                    <input asp-for="ChapterForm.ChapterId" type="hidden" />
                    <div class="row g-3">
                        <div class="col-md-5">
                            <label class="form-label fw-semibold text-uppercase small text-muted">Chapter Title</label>
                            <input asp-for="ChapterForm.Title" class="form-control" placeholder="e.g. Introduction to Factoring" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label fw-semibold text-uppercase small text-muted">Order</label>
                            <input asp-for="ChapterForm.Order" class="form-control" type="number" min="1" />
                        </div>
                        <div class="col-md-5">
                            <label class="form-label fw-semibold text-uppercase small text-muted">Learning Goal</label>
                            <input asp-for="ChapterForm.Goal" class="form-control" placeholder="Students will be able to..." />
                        </div>
                    </div>
                    <div class="mt-3">
                        <label class="form-label fw-semibold text-uppercase small text-muted">Chapter Content</label>
                        <textarea asp-for="ChapterForm.Content" class="form-control" rows="7"
                                  placeholder="Write your lesson notes, worked examples, and guidance here..."></textarea>
                    </div>
                    <div class="mt-3 d-flex gap-2">
                        <button type="submit" class="btn-new-quiz">
                            @(isEditingChapter ? "Update Chapter" : "Save Chapter")
                        </button>
                        @if (isEditingChapter)
                        {
                            <a asp-page="/Teacher/MyTopics" asp-route-topicId="@Model.ActiveTopicId" class="btn-edit">Cancel</a>
                        }
                        else
                        {
                            <button type="button" class="btn-edit" onclick="clearChapterForm()">Clear</button>
                        }
                    </div>
                </form>

                <!-- Chapter List -->
                @if (Model.Chapters.Any())
                {
                    <div style="border-top:1px solid #f0ebe4;padding-top:1.25rem;">
                        <div class="content-card-title mb-3">
                            Chapters
                            <span style="font-size:0.8rem;font-weight:400;color:#888;margin-left:0.4rem;">@Model.Chapters.Count total</span>
                        </div>
                        <div class="chapter-list">
                            @foreach (var chapter in Model.Chapters)
                            {
                                <div class="chapter-item">
                                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                                        <div style="flex:1;min-width:0;">
                                            <div class="chapter-title">@chapter.Title</div>
                                            <div class="chapter-meta">
                                                Chapter @chapter.Order
                                                @if (!string.IsNullOrWhiteSpace(chapter.Goal))
                                                {
                                                    <span>&middot; @chapter.Goal</span>
                                                }
                                            </div>
                                            @if (!string.IsNullOrWhiteSpace(chapter.Content))
                                            {
                                                <div class="chapter-content">
                                                    @(chapter.Content.Length > 160
                                                        ? chapter.Content.Substring(0, 160) + "…"
                                                        : chapter.Content)
                                                </div>
                                            }
                                        </div>
                                        <div class="d-flex gap-2 flex-shrink-0">
                                            <a asp-page="/Teacher/MyTopics"
                                               asp-route-topicId="@Model.ActiveTopicId"
                                               asp-route-chapterId="@chapter.ChapterId"
                                               class="btn-edit">Edit</a>
                                            <form method="post" asp-page-handler="DeleteChapter" class="d-inline"
                                                  onsubmit="return confirm('Delete \'@chapter.Title\'? This cannot be undone.')">
                                                <input type="hidden" name="chapterId" value="@chapter.ChapterId" />
                                                <button type="submit" class="btn-edit" style="color:#c0392b;border-color:#e5aaaa;">Delete</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div style="border-top:1px solid #f0ebe4;padding-top:1rem;">
                        <div class="empty-state">No chapters yet. Fill in the form above to add your first chapter.</div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function clearChapterForm() {
            document.getElementById('ChapterForm_Title').value = '';
            document.getElementById('ChapterForm_Goal').value = '';
            document.getElementById('ChapterForm_Content').value = '';
            document.getElementById('ChapterForm_Order').value = '1';
            document.getElementById('ChapterForm_ChapterId').value = '';
        }
    </script>
}
