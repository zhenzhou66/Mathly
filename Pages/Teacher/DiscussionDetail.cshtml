@page "/teacher/discussion/{discussionId}"
@model Mathly.Pages.Teacher.DiscussionDetailModel
@{
    Layout = "_LayoutTeacher";
    ViewData["Title"] = Model.QuestionTitle;
    ViewData["ActivePage"] = "Discussion";
    ViewData["TeacherName"] = Model.TeacherName;
}

@section Styles {
    <link rel="stylesheet" href="~/css/TeacherDiscussionDetail.css" asp-append-version="true" />
}

<div class="page-header">
    <a asp-page="/Teacher/Discussion" class="discussion-detail-back">← Back to Discussions</a>
    <h1 class="page-title">@Model.QuestionTitle</h1>
    <p class="page-subtitle">Asked by @Model.AuthorName &middot; @Model.PostedAgo</p>
</div>

<div class="content-card mb-3">
    <div class="discussion-detail-question">@Model.QuestionText</div>
</div>

<div class="content-card mb-3">
    <div class="content-card-title mb-3">Comments (@Model.Comments.Count)</div>
    @if (Model.Comments.Any())
    {
        @foreach (var c in Model.Comments)
        {
            <div class="discussion-comment-row">
                <div class="discussion-comment-author">@c.AuthorName <span class="discussion-comment-time">&middot; @c.PostedAgo</span></div>
                <div class="discussion-comment-text">@c.CommentText</div>
                <button type="button" class="comment-like-btn" data-comment-id="@c.CommentID" data-liked="false">
                    <span class="comment-like-heart">♡</span>
                    <span class="comment-like-count">@c.LikeCount</span>
                </button>
            </div>
        }
    }
    else
    {
        <div class="empty-state">No comments yet — be the first to reply!</div>
    }
</div>

<div class="content-card">
    <div class="content-card-title mb-3">Add a comment</div>
    <form method="post">
        <div class="mb-2">
            <textarea asp-for="NewComment" class="form-control" rows="3" placeholder="Write a reply..."></textarea>
        </div>
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
                ⚠️ @Model.ErrorMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <button type="submit" class="btn-add-topic">Post comment</button>
    </form>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.comment-like-btn').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var liked = btn.dataset.liked === 'true';
                var newLiked = !liked;
                var commentId = btn.dataset.commentId;
                var heart = btn.querySelector('.comment-like-heart');
                var countEl = btn.querySelector('.comment-like-count');
                var currentCount = parseInt(countEl.textContent, 10) || 0;
                var token = document.querySelector('input[name="__RequestVerificationToken"]').value;

                // Optimistic UI update — flip the heart and count immediately.
                btn.dataset.liked = newLiked ? 'true' : 'false';
                btn.classList.toggle('comment-like-active', newLiked);
                heart.textContent = newLiked ? '♥' : '♡';
                countEl.textContent = Math.max(currentCount + (newLiked ? 1 : -1), 0);

                fetch(window.location.pathname + '?handler=ToggleLike', {
                    method: 'POST',
                    body: new URLSearchParams({
                        commentId: commentId,
                        increment: newLiked,
                        __RequestVerificationToken: token
                    })
                }).catch(function () {
                    // Revert on network/server failure.
                    btn.dataset.liked = liked ? 'true' : 'false';
                    btn.classList.toggle('comment-like-active', liked);
                    heart.textContent = liked ? '♥' : '♡';
                    countEl.textContent = currentCount;
                });
            });
        });
    </script>
}
