@page
@model Mathly.Pages.Admin.BadgeManagementModel
@using System.Text.Encodings.Web
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Badge Management";
    ViewData["ActivePage"] = "Badges";
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h1 class="page-title mb-0">Badge Management</h1>
    </div>
</div>

@if (Model.SuccessMessage != null)
{
    <div class="alert alert-success mb-3">@Model.SuccessMessage</div>
}
@if (Model.ErrorMessage != null)
{
    <div class="alert alert-danger mb-3">@Model.ErrorMessage</div>
}

<div class="row g-3">
    <!-- LEFT: Badges Table -->
    <div class="col-lg-12" id="tableCol">
        <div class="content-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="content-card-title mb-0">All Badges</div>
                <button type="button" class="btn-new-quiz" onclick="openAddPanel()">+ Add Badge</button>
            </div>

            <table class="table table-borderless topics-table mb-0">
                <thead>
                    <tr>
                        <th>Icon</th>
                        <th>Badge Name</th>
                        <th>Required EXP</th>
                        <th>Students Earned</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Badges.Any())
                    {
                        @foreach (var b in Model.Badges)
                        {
                            <tr>
                                <td>
                                    <div style="width:36px;height:36px;border-radius:50%;background:#EEF2FF;color:#4F46E5;display:flex;align-items:center;justify-content:center;font-size:1.2rem;">
                                        <i class="bi @b.IconClass"></i>
                                    </div>
                                </td>
                                <td><div class="fw-semibold">@b.BadgeName</div></td>
                                <td><span class="badge bg-light text-dark border">@b.ExpPoints EXP</span></td>
                                <td>@b.StudentsEarned students</td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <button type="button" class="btn-edit" 
                                                onclick="openEditPanel('@b.BadgeID', '@JavaScriptEncoder.Default.Encode(b.BadgeName)', @b.ExpPoints, '@b.IconClass')">
                                            Edit
                                        </button>
                                        <form method="post" asp-page-handler="DeleteBadge" onsubmit="return confirm('Are you sure you want to delete this badge?');" style="display:inline;">
                                            <input type="hidden" name="badgeId" value="@b.BadgeID" />
                                            <button type="submit" class="btn-edit text-danger border-danger">Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="5" class="empty-state">No badges found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- RIGHT: Side Panel -->
    <div class="col-lg-4" id="panelCol" style="display:none;">

        <!-- ADD BADGE FORM -->
        <div class="content-card" id="addPanel" style="display:none;">
            <div class="content-card-title mb-3">Add New Badge</div>
            <form method="post" asp-page-handler="AddBadge">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Badge Name</label>
                    <input type="text" asp-for="NewBadgeName" class="form-control" placeholder="e.g. Math Master" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Required EXP</label>
                    <input type="number" asp-for="NewExpPoints" class="form-control" required />
                </div>

                <!-- 5 PRESET ICONS ROW -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">Select Icon</label>
                    <input type="hidden" id="addIconInput" asp-for="NewIconClass" value="@Model.PresetIcons[0]" />
                    <div class="d-flex gap-2 justify-content-between p-2 border rounded bg-light">
                        @foreach (var icon in Model.PresetIcons)
                        {
                            <button type="button" 
                                    class="btn btn-outline-primary add-icon-btn p-2 flex-fill @(icon == Model.PresetIcons[0] ? "active" : "")" 
                                    data-icon="@icon"
                                    onclick="pickAddIcon('@icon', this)">
                                <i class="bi @icon fs-4"></i>
                            </button>
                        }
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn-new-quiz flex-grow-1">Add Badge</button>
                    <button type="button" class="btn-edit" onclick="closePanel()">Cancel</button>
                </div>
            </form>
        </div>

        <!-- EDIT BADGE FORM -->
        <div class="content-card" id="editPanel" style="display:none;">
            <div class="content-card-title mb-3">Edit Badge</div>
            <form method="post" asp-page-handler="EditBadge">
                <input type="hidden" name="badgeId" id="editBadgeId" />
                <div class="mb-3">
                    <label class="form-label fw-semibold">Badge Name</label>
                    <input type="text" name="badgeName" id="editBadgeName" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Required EXP</label>
                    <input type="number" name="expPoints" id="editExpPoints" class="form-control" required />
                </div>

                <!-- 5 PRESET ICONS ROW -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">Select Icon</label>
                    <input type="hidden" id="editIconInput" name="iconClass" value="@Model.PresetIcons[0]" />
                    <div class="d-flex gap-2 justify-content-between p-2 border rounded bg-light">
                        @foreach (var icon in Model.PresetIcons)
                        {
                            <button type="button" 
                                    class="btn btn-outline-primary edit-icon-btn p-2 flex-fill" 
                                    data-icon="@icon" 
                                    onclick="pickEditIcon('@icon', this)">
                                <i class="bi @icon fs-4"></i>
                            </button>
                        }
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn-new-quiz flex-grow-1">Save Changes</button>
                    <button type="button" class="btn-edit" onclick="closePanel()">Cancel</button>
                </div>
            </form>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        function pickAddIcon(iconClass, btn) {
            document.getElementById('addIconInput').value = iconClass;
            document.querySelectorAll('.add-icon-btn').forEach(b => b.classList.remove('active'));
            if (btn) btn.classList.add('active');
        }

        function pickEditIcon(iconClass, btn) {
            document.getElementById('editIconInput').value = iconClass;
            document.querySelectorAll('.edit-icon-btn').forEach(b => b.classList.remove('active'));
            if (btn) btn.classList.add('active');
        }

        function showPanelCol() {
            var tableCol = document.getElementById('tableCol');
            tableCol.classList.remove('col-lg-12');
            tableCol.classList.add('col-lg-8');
            document.getElementById('panelCol').style.display = 'block';
        }

        function hideAllPanels() {
            document.getElementById('addPanel').style.display = 'none';
            document.getElementById('editPanel').style.display = 'none';
        }

        function openAddPanel() {
            hideAllPanels();
            document.getElementById('addPanel').style.display = 'block';
            showPanelCol();

            var defaultIcon = '@Model.PresetIcons[0]';
            var firstBtn = document.querySelector('.add-icon-btn[data-icon="' + defaultIcon + '"]');
            pickAddIcon(defaultIcon, firstBtn);

            document.getElementById('panelCol').scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        function openEditPanel(badgeId, badgeName, expPoints, iconClass) {
            hideAllPanels();

            document.getElementById('editBadgeId').value = badgeId;
            document.getElementById('editBadgeName').value = badgeName;
            document.getElementById('editExpPoints').value = expPoints;

            var currentIcon = iconClass || '@Model.PresetIcons[0]';
            var matchingBtn = document.querySelector('.edit-icon-btn[data-icon="' + currentIcon + '"]');
            pickEditIcon(currentIcon, matchingBtn);

            document.getElementById('editPanel').style.display = 'block';
            showPanelCol();
            document.getElementById('panelCol').scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        function closePanel() {
            hideAllPanels();
            document.getElementById('panelCol').style.display = 'none';

            var tableCol = document.getElementById('tableCol');
            tableCol.classList.remove('col-lg-8');
            tableCol.classList.add('col-lg-12');
        }
    </script>
}