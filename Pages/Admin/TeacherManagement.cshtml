@page 
@model Mathly.Pages.Admin.TeacherManagementModel
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Teacher Management";
    ViewData["ActivePage"] = "Teachers";
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h1 class="page-title mb-0">Teacher Management</h1>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success mb-3">@Model.SuccessMessage</div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger mb-3">@Model.ErrorMessage</div>
}

<div class="row g-3">

    <!-- LEFT: Teachers Table -->
    <div class="col-lg-12" id="tableCol">
        <div class="content-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="content-card-title mb-3">All Teachers</div>
                <button type="button" class="btn-new-quiz" onclick="openAddPanel()">+ Add Teacher</button>
            </div>

            <table class="table table-borderless topics-table mb-0">
                <thead>
                    <tr>
                        <th>Teacher</th>
                        <th>Topics</th>
                        <th>Students</th>
                        <th>Status</th>
                        <th>Action</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Teachers.Any())
                    {
                        @foreach (var t in Model.Teachers)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div style="width:32px;height:32px;border-radius:50%;background:#4CBFBF;color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;flex-shrink:0;">
                                            @t.Name.Substring(0, 1).ToUpper()
                                        </div>
                                        <div>
                                            <div class="fw-semibold">@t.Name</div>
                                            <div style="font-size:0.8rem;color:#888;">@t.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td>@t.TopicsDisplay</td>
                                <td>@t.StudentCount</td>
                                <td>
                                    @if (t.Status == "active")
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Suspended</span>
                                    }
                                </td>
                                <td class="d-flex gap-1">
                                    <button type="button" class="btn-edit"
                                            data-userid="@t.UserID" data-name="@t.Name" data-email="@t.Email"
                                            data-phone="@t.PhoneNumber" data-qualification="@t.Qualification"
                                            onclick="openEditPanel(this)">edit</button>

                                    <button type="button" class="btn-assign"
                                            data-userid="@t.UserID" data-name="@t.Name"
                                            data-assigned="@t.AssignedTopicIds"
                                            onclick="openTopicsPanel(this)">assign</button>                                   
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="5" class="empty-state">No teachers yet.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- RIGHT: Panel -->
    <div class="col-lg-4" id="panelCol" style="display:none;">

        <!-- ADD TEACHER FORM -->
        <div class="content-card" id="addPanel" style="display:none;">
            <div class="content-card-title mb-3">Add Teacher</div>
            <form method="post" asp-page-handler="AddTeacher">
                <div class="mb-3">
                    <label class="profile-label">Full Name</label>
                    <input type="text" name="NewName" class="form-control" placeholder="Ms. / Mr. Full Name" required />
                </div>
                <div class="mb-3">
                    <label class="profile-label">Email</label>
                    <input type="email" name="NewEmail" class="form-control" placeholder="teacher@mathly.edu.my" required />
                </div>
                <div class="mb-3">
                    <label class="profile-label">Phone</label>
                    <input type="text" name="NewPhone" class="form-control" placeholder="+60 ..." />
                </div>
                <div class="mb-3">
                    <label class="profile-label">Highest Qualification</label>
                    <input type="text" name="NewQualification" class="form-control" placeholder="B.Sc. Mathematics" />
                </div>
                <div class="mb-3">
                    <label class="profile-label">Assign Topics</label>
                    <div style="max-height:160px;overflow-y:auto;border:1px solid #ddd;border-radius:6px;padding:0.5rem;">
                        @foreach (var topic in Model.AllTopics)
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="NewTopicIds" value="@topic.TopicID" id="newTopic_@topic.TopicID" />
                                <label class="form-check-label" for="newTopic_@topic.TopicID">@topic.TopicName</label>
                            </div>
                        }
                    </div>
                </div>
                <div class="mb-3">
                    <label class="profile-label">Initial Password</label>
                    <input type="password" name="NewPassword" class="form-control" placeholder="Temporary password" required />
                </div>
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn-new-quiz flex-grow-1">Add Teacher</button>
                    <button type="button" class="btn-edit" onclick="closePanel()">Cancel</button>
                </div>
            </form>
        </div>

        <!-- EDIT TEACHER FORM -->
        <div class="content-card" id="editPanel" style="display:none;">
            <div class="content-card-title mb-3" id="editPanelTitle">Edit Teacher</div>
            <form method="post" asp-page-handler="EditTeacher">
                <input type="hidden" name="teacherId" id="editTeacherId" />
                <div class="mb-3">
                    <label class="profile-label">Full Name</label>
                    <input type="text" name="name" id="editName" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="profile-label">Email</label>
                    <input type="email" name="email" id="editEmail" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="profile-label">Phone</label>
                    <input type="text" name="phoneNumber" id="editPhone" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="profile-label">Highest Qualification</label>
                    <input type="text" name="qualification" id="editQualification" class="form-control" />
                </div>
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn-new-quiz flex-grow-1">Save Changes</button>
                    <button type="button" class="btn-edit" onclick="closePanel()">Cancel</button>
                </div>
            </form>
        </div>

        <!-- ASSIGN TOPICS FORM -->
        <div class="content-card" id="topicsPanel" style="display:none;">
            <div class="content-card-title mb-3" id="topicsPanelTitle">Assign Topics</div>
            <form method="post" asp-page-handler="AssignTopics">
                <input type="hidden" name="teacherId" id="topicsTeacherId" />
                <div style="max-height:220px;overflow-y:auto;border:1px solid #ddd;border-radius:6px;padding:0.5rem;">
                    @foreach (var topic in Model.AllTopics)
                    {
                        <div class="form-check">
                            <input class="form-check-input topics-checkbox" type="checkbox" name="topicIds" value="@topic.TopicID" id="topicChk_@topic.TopicID" />
                            <label class="form-check-label" for="topicChk_@topic.TopicID">@topic.TopicName</label>
                        </div>
                    }
                </div>
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn-new-quiz flex-grow-1">Save Topics</button>
                    <button type="button" class="btn-edit" onclick="closePanel()">Cancel</button>
                </div>
            </form>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        function showPanelCol() {
            var tableCol = document.getElementById('tableCol');
            tableCol.classList.remove('col-lg-12');
            tableCol.classList.add('col-lg-8');
            document.getElementById('panelCol').style.display = 'block';
        }

        function hideAllPanels() {
            document.getElementById('addPanel').style.display = 'none';
            document.getElementById('editPanel').style.display = 'none';
            document.getElementById('topicsPanel').style.display = 'none';
        }

        function openAddPanel() {
            hideAllPanels();
            document.getElementById('addPanel').style.display = 'block';
            showPanelCol();
            document.getElementById('panelCol').scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        function openEditPanel(btn) {
            var d = btn.dataset;
            hideAllPanels();

            document.getElementById('editPanelTitle').textContent = 'Edit ' + d.name;
            document.getElementById('editTeacherId').value = d.userid;
            document.getElementById('editName').value = d.name;
            document.getElementById('editEmail').value = d.email;
            document.getElementById('editPhone').value = d.phone;
            document.getElementById('editQualification').value = d.qualification;

            document.getElementById('editPanel').style.display = 'block';
            showPanelCol();
            document.getElementById('panelCol').scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        function openTopicsPanel(btn) {
            var d = btn.dataset;
            hideAllPanels();

            document.getElementById('topicsPanelTitle').textContent = 'Assign Topics — ' + d.name;
            document.getElementById('topicsTeacherId').value = d.userid;

            var assigned = (d.assigned || '').split(',').filter(Boolean);
            document.querySelectorAll('.topics-checkbox').forEach(function (chk) {
                chk.checked = assigned.includes(chk.value);
            });

            document.getElementById('topicsPanel').style.display = 'block';
            showPanelCol();
            document.getElementById('panelCol').scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        function closePanel() {
            hideAllPanels();
            document.getElementById('panelCol').style.display = 'none';

            var tableCol = document.getElementById('tableCol');
            tableCol.classList.remove('col-lg-8');
            tableCol.classList.add('col-lg-12');
        }
    </script>
}