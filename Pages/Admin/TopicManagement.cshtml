@page
@model Mathly.Pages.Admin.TopicManagementModel
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Topic Management";
    ViewData["ActivePage"] = "Topics";
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h1 class="page-title mb-0">Topic Management</h1>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success mb-3">@Model.SuccessMessage</div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger mb-3">@Model.ErrorMessage</div>
}

<div class="row g-3">

    <!-- LEFT: Topics Table -->
    <div class="col-lg-12" id="tableCol">
        <div class="content-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="content-card-title mb-3">All Topics</div>
                <button type="button" class="btn-new-quiz" onclick="openAddPanel()">+ Add Topic</button>
            </div>

            <table class="table table-borderless topics-table mb-0">
                <thead>
                    <tr>
                        <th>Topic</th>
                        <th>Teacher</th>
                        <th>Quizzes</th>
                        <th>Students</th>
                        <th>Action</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Topics.Any())
                    {
                        @foreach (var t in Model.Topics)
                        {
                            <tr>
                                <td class="fw-semibold">@t.TopicName</td>
                                <td>@t.TeacherName</td>
                                <td>@t.QuizCount</td>
                                <td>@t.StudentCount</td>
                                <td class="d-flex gap-1">
                                    <button type="button" class="btn-edit"
                                            data-topicid="@t.TopicID"
                                            data-topicname="@t.TopicName"
                                            data-teacherid="@t.TeacherID"
                                            onclick="openEditPanel(this)">edit</button>

                                    <form method="post" asp-page-handler="DeleteTopic" style="display:inline"
                                          onsubmit="return confirm('Delete topic \'@t.TopicName\'? This cannot be undone.');">
                                        <input type="hidden" name="topicId" value="@t.TopicID" />
                                        <button type="submit" class="btn-edit">delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="5" class="empty-state">No topics yet.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- RIGHT: Panel -->
    <div class="col-lg-4" id="panelCol" style="display:none;">

        <!-- ADD TOPIC FORM -->
        <div class="content-card" id="addPanel" style="display:none;">
            <div class="content-card-title mb-3">Add Topic</div>
            <form method="post" asp-page-handler="AddTopic">
                <div class="mb-3">
                    <label class="profile-label">Topic Name</label>
                    <input type="text" name="NewTopicName" class="form-control" placeholder="e.g. Probability" required />
                </div>
                <div class="mb-3">
                    <label class="profile-label">Assign Teacher</label>
                    <select name="NewTeacherId" class="form-select">
                        <option value="">— Unassigned —</option>
                        @foreach (var teacher in Model.AllTeachers)
                        {
                            <option value="@teacher.UserID">@teacher.TeacherName</option>
                        }
                    </select>
                </div>
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn-new-quiz flex-grow-1">Add Topic</button>
                    <button type="button" class="btn-edit" onclick="closePanel()">Cancel</button>
                </div>
            </form>
        </div>

        <!-- EDIT TOPIC FORM -->
        <div class="content-card" id="editPanel" style="display:none;">
            <div class="content-card-title mb-3" id="editPanelTitle">Edit Topic</div>
            <form method="post" asp-page-handler="EditTopic">
                <input type="hidden" name="topicId" id="editTopicId" />
                <div class="mb-3">
                    <label class="profile-label">Topic Name</label>
                    <input type="text" name="topicName" id="editTopicName" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="profile-label">Assign Teacher</label>
                    <select name="teacherId" id="editTeacherId" class="form-select">
                        <option value="">— Unassigned —</option>
                        @foreach (var teacher in Model.AllTeachers)
                        {
                            <option value="@teacher.UserID">@teacher.TeacherName</option>
                        }
                    </select>
                </div>
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn-new-quiz flex-grow-1">Save Changes</button>
                    <button type="button" class="btn-edit" onclick="closePanel()">Cancel</button>
                </div>
            </form>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        function showPanelCol() {
            var tableCol = document.getElementById('tableCol');
            tableCol.classList.remove('col-lg-12');
            tableCol.classList.add('col-lg-8');
            document.getElementById('panelCol').style.display = 'block';
        }

        function hideAllPanels() {
            document.getElementById('addPanel').style.display = 'none';
            document.getElementById('editPanel').style.display = 'none';
        }

        function openAddPanel() {
            hideAllPanels();
            document.getElementById('addPanel').style.display = 'block';
            showPanelCol();
            document.getElementById('panelCol').scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        function openEditPanel(btn) {
            var d = btn.dataset;
            hideAllPanels();

            document.getElementById('editPanelTitle').textContent = 'Edit ' + d.topicname;
            document.getElementById('editTopicId').value = d.topicid;
            document.getElementById('editTopicName').value = d.topicname;
            document.getElementById('editTeacherId').value = d.teacherid || '';

            document.getElementById('editPanel').style.display = 'block';
            showPanelCol();
            document.getElementById('panelCol').scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        function closePanel() {
            hideAllPanels();
            document.getElementById('panelCol').style.display = 'none';

            var tableCol = document.getElementById('tableCol');
            tableCol.classList.remove('col-lg-8');
            tableCol.classList.add('col-lg-12');
        }
    </script>
}