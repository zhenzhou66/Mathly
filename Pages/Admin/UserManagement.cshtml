@page
@model Mathly.Pages.Admin.UserManagementModel
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "User Management";
    ViewData["ActivePage"] = "Users";

    var studentsOnly = Model.Users?.Where(u => string.Equals(u.Role, "student", StringComparison.OrdinalIgnoreCase)) ?? Enumerable.Empty<dynamic>();
}

<div class="page-header">
    <h1 class="page-title">User Management</h1>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success mb-3">@Model.SuccessMessage</div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger mb-3">@Model.ErrorMessage</div>
}

<div class="row g-3">

    <!-- LEFT: Users Table -->
    <div class="col-lg-12" id="tableCol">
        <div class="content-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="content-card-title">Students</div>
                <input type="text" id="userSearch" class="form-control" style="max-width:240px;"
                       placeholder="Search by name or email..." />
            </div>

            <table class="table table-borderless topics-table mb-0" id="usersTable">
                <thead>
                    <tr>
                        <th>UserID</th>
                        <th>Name</th>
                        <th>Phone Number</th>
                        <th>Age</th>
                        <th>Birth Date</th>                        
                        <th>School</th>
                        <th>Date Joined</th>
                        <th>Study Level</th>
                        <th>Exp Points</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (studentsOnly.Any())
                    {
                        @foreach (var u in studentsOnly)
                        {
                            <tr class="user-row" data-search="@($"{u.Name} {u.Email}".ToLower())">
                                <!-- UserID -->
                                <td>@u.UserID</td>

                                <!-- Name & Email -->
                                <td>
                                    <div class="fw-semibold">@u.Name</div>
                                    <div style="font-size:0.8rem;color:#888;">@u.Email</div>
                                </td>

                                <!-- Phone Number -->
                                <td>@(string.IsNullOrEmpty(u.PhoneNumber) ? "-" : u.PhoneNumber)</td>

                                <!-- Age -->
                                <td>@u.Age</td>

                                <!-- Birth Date -->
                                <td>@(u.BirthDate != null ? u.BirthDate.ToString("d MMM yyyy") : "-")</td>

                                <!-- School -->
                                <td>@(string.IsNullOrEmpty(u.School) ? "-" : u.School)</td>

                                <!-- Date Joined -->
                                <td>@(u.DateJoined != null ? u.DateJoined.ToString("d MMM yyyy") : "-")</td>

                                <!-- Study Level -->
                                <td>@(string.IsNullOrEmpty(u.StudyLevel) ? "-" : u.StudyLevel)</td>                                
                                
                                <!-- Exp Points -->
                                <td>@(u.ExpPoints ?? 0)</td>

                                <!-- Status -->
                                <td>
                                    @if (u.Status == "active")
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Suspended</span>
                                    }
                                </td>

                                <!-- Actions -->
                                <td class="d-flex gap-1">
                                    <button type="button" class="btn-edit"
                                            data-userid="@u.UserID"
                                            data-name="@u.Name"
                                            data-email="@u.Email"
                                            data-phone="@u.PhoneNumber"
                                            data-role="@u.Role"
                                            data-level="@u.StudyLevel"
                                            data-school="@u.School"
                                            onclick="openEditPanel(this)">
                                        edit
                                    </button>

                                    @if (u.Status == "active")
                                    {
                                        <form method="post" asp-page-handler="Suspend" style="display:inline"
                                              onsubmit="return confirm('Suspend @u.UserID?');">
                                            <input type="hidden" name="userId" value="@u.UserID" />
                                            <button type="submit" class="btn-edit">suspend</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form method="post" asp-page-handler="Restore" style="display:inline">
                                            <input type="hidden" name="userId" value="@u.UserID" />
                                            <button type="submit" class="btn-edit">restore</button>
                                        </form>
                                        <form method="post" asp-page-handler="DeleteUser" style="display:inline"
                                              onsubmit="return confirm('Permanently delete @u.UserID? This cannot be undone.');">
                                            <input type="hidden" name="userId" value="@u.UserID" />
                                            <button type="submit" class="btn-edit">delete</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="11" class="empty-state text-center">No students found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- RIGHT: Edit Panel -->
    <div class="col-lg-4" id="editCol" style="display:none;">
        <div class="content-card">
            <div class="content-card-title mb-3" id="editPanelTitle">Edit Student</div>

            <form method="post" asp-page-handler="EditUser" id="editForm" style="display:none;">
                <input type="hidden" name="userId" id="editUserId" />

                <div class="mb-3">
                    <label class="profile-label">Full Name</label>
                    <input type="text" name="name" id="editName" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label class="profile-label">Email</label>
                    <input type="email" name="email" id="editEmail" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="profile-label">Phone Number</label>
                    <input type="text" name="phoneNumber" id="editPhone" class="form-control" />
                </div>

                <div id="studentFields">
                    <div class="mb-3">
                        <label class="profile-label">Study Level</label>
                        <select name="level" id="editLevel" class="form-select">
                            <option value="Form 1">Form 1</option>
                            <option value="Form 2">Form 2</option>
                            <option value="Form 3">Form 3</option>
                            <option value="Form 4">Form 4</option>
                            <option value="Form 5">Form 5</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="profile-label">School</label>
                        <input type="text" name="school" id="editSchool" class="form-control" />
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn-new-quiz flex-grow-1">Save Changes</button>
                    <button type="button" class="btn-edit" onclick="closeEditPanel()">Cancel</button>
                </div>
            </form>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        // Client-side search
        document.getElementById('userSearch').addEventListener('input', function () {
            var term = this.value.toLowerCase();
            document.querySelectorAll('.user-row').forEach(function (row) {
                row.style.display = row.dataset.search.includes(term) ? '' : 'none';
            });
        });

        function openEditPanel(btn) {
            var d = btn.dataset;

            document.getElementById('editPanelTitle').textContent = 'Edit ' + (d.name || '');
            var emptyElement = document.getElementById('editPanelEmpty');
            if (emptyElement) emptyElement.style.display = 'none';
            document.getElementById('editForm').style.display = 'block';

            document.getElementById('editUserId').value = d.userid || '';
            document.getElementById('editName').value = d.name || '';
            document.getElementById('editEmail').value = d.email || '';
            document.getElementById('editPhone').value = d.phone || '';

            var studentFields = document.getElementById('studentFields');
            if (d.role === 'student') {
                studentFields.style.display = 'block';
                document.getElementById('editLevel').value = d.level || '';
                document.getElementById('editSchool').value = d.school || '';
            } else {
                studentFields.style.display = 'none';
            }

            var tableCol = document.getElementById('tableCol');
            tableCol.classList.remove('col-lg-12');
            tableCol.classList.add('col-lg-8');

            document.getElementById('editCol').style.display = 'block';
            document.getElementById('editCol').scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        function closeEditPanel() {
            document.getElementById('editCol').style.display = 'none';
            
            var tableCol = document.getElementById('tableCol');
            tableCol.classList.remove('col-lg-8');
            tableCol.classList.add('col-lg-12');

            document.getElementById('editForm').style.display = 'none';
            document.getElementById('editForm').reset();
            var emptyElement = document.getElementById('editPanelEmpty');
            if (emptyElement) emptyElement.style.display = 'block';
            document.getElementById('editPanelTitle').textContent = 'Select a user to edit';
        }
    </script>
}